{
	"less.compile": {
		"compress": false, //是否压缩
		"sourceMap": false, //是否生成map文件，有了这个可以在调试台看到less行数
		"out": "${workspaceRoot}\\", // 输出文件目录 这里为css文件夹
		"outExt": ".css" // 输出文件的后缀
	},
	"editor.tabSize": 4, // 制表符长度
	"editor.insertSpaces": false, // true: 空格缩进 false:制表符缩进
	"flow-icons.folders.associations": {
		"cyu": "jinja",
		"obsidian": "home",
		"arrow_annotation": "jinja",
		"time_tag": "jinja",
		"editor": "jinja",
		"processor": "jinja"
	},
	"svg.preview.background": "dark-transparent",
	"todo-tree.general.tags": [
		"TODO ",
		"FIXME ",
		"HACK ",
		"NOTE ",
		" - ",
		" ─── ",
		"#region ! "
	],
	"todo-tree.highlights.customHighlight": {
		" - ": {
			"icon": "note",
			"type": "whole-line",
			"foreground": "#ffffff",
			"background": "#181926",
			"rulerColour": "#a78bfa",
			"iconColour": "#a78bfa"
		},
		"TODO ": {
			"icon": "alert",
			// "type": "whole-line",
			// "type": "text",
			"type": "tag-and-comment",
			"foreground": "#fff",
			"background": "#673ab7",
			"rulerColour": "#673ab7",
			"iconColour": "#673ab7"
		},
		"#region ! ": {
			"icon": "versions",
			"type": "whole-line",
			"foreground": "#fff",
			"background": "#673ab7",
			"rulerColour": "#673ab7",
			"iconColour": "#673ab7"
		},
		" ─── ": {
			"icon": "versions",
			"type": "whole-line",
			"foreground": "#ffffffac",
			"background": "#492686",
			"rulerColour": "#673ab7",
			"iconColour": "#673ab7"
		}
	},
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "never" // 导入未使用不报错
	}
}