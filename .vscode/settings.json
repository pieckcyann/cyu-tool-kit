{
	"editor.tabSize": 4, // 制表符长度
	"editor.insertSpaces": false, // true: 空格缩进 false:制表符缩进
	"flow-icons.folders.associations": {
		"cyu": "jinja",
		"arrow-annotation": "purple",
		"inline-code-highlight": "blue",
		"time-tag": "brown",
		"obsidian": "home",
		"obsidian/codeblock": "home",
		"obsidian/command": "home",
		"obsidian/preview": "home",
		"time_tag": "jinja",
		"editor": "jinja",
		"processor": "jinja"
	},
	"svg.preview.background": "dark-transparent",
	"todo-tree.general.tags": [
		"TODO ",
		"FIXME ",
		"HACK ",
		"NOTE ",
		" - ",
		" ─── ",
		"#region "
	],
	"todo-tree.highlights.customHighlight": {
		" - ": {
			"icon": "note",
			"type": "whole-line",
			"foreground": "#ffffff",
			"background": "#181926",
			"rulerColour": "#a78bfa",
			"iconColour": "#a78bfa"
		},
		"TODO ": {
			"icon": "alert",
			// "type": "whole-line",
			// "type": "text",
			"type": "text-and-comment",
			"foreground": "#ffffffac",
			"background": "#492686",
			"rulerColour": "#673ab7",
			"iconColour": "#673ab7"
		},
		"#region ! ": {
			"icon": "versions",
			"type": "whole-line",
			"foreground": "#fff",
			"background": "#673ab7",
			"rulerColour": "#673ab7",
			"iconColour": "#673ab7"
		},
		" ─── ": {
			"icon": "versions",
			"type": "whole-line",
			"foreground": "#ffffffac",
			"background": "#492686",
			"rulerColour": "#673ab7",
			"iconColour": "#673ab7"
		}
	},
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "never" // 导入未使用不报错
	}
}