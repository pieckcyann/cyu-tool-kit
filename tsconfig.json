{
	"compilerOptions": {
		// "baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		// "moduleResolution": "node",
		"moduleResolution": "Bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"lib": [
			"DOM",
			"ES5",
			"ES6",
			"ES7",
			"DOM.Iterable",
			"ESNext"
		],
		"jsx": "react-jsx",
		"useUnknownInCatchVariables": false
	},
	"include": [
		"**/*.ts",
		"**/*.tsx"
	]
}